[user]
    name = Ramzi Sayyid
    email = code@lecid.me

[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate --all
    undo = reset HEAD~1 --mixed
    wip = commit -am 'wip'

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[rebase]
    autoStash = true

[merge]
    conflictstyle = zdiff3

[diff]
    algorithm = histogram
    colorMoved = default

[core]
    autocrlf = input
    pager = bat --plain --paging=always

[interactive]
    diffFilter = bat --plain --color=always
